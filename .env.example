# Environment Configuration for Sepsis Prediction API
# Copy this to .env and update values as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# Model Configuration
ACTIVE_MODEL=xgboost
XGBOOST_MODEL_PATH=model/xgb_model.pkl
RANDOM_FOREST_MODEL_PATH=model/rf_model.pkl
FEATURE_NAMES_PATH=model/feature_names.txt

# Risk Thresholds
RISK_LOW_THRESHOLD=0.3
RISK_MODERATE_THRESHOLD=0.5
RISK_HIGH_THRESHOLD=0.7
RISK_CRITICAL_THRESHOLD=0.85

# Database Configuration (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/sepsis_predictions
SQLALCHEMY_ECHO=false

# Redis Cache (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_ENABLED=false

# Authentication (Optional)
SECRET_KEY=your-secret-key-here-change-in-production
TOKEN_EXPIRE_MINUTES=60
AUTH_ENABLED=false

# CORS Configuration
ALLOWED_ORIGINS=['*']
ALLOW_CREDENTIALS=true
ALLOW_METHODS=['*']
ALLOW_HEADERS=['*']

# Email Notifications (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_ENABLED=false

# SHAP Configuration
SHAP_ENABLED=true
SHAP_EXPLANATION_MODE=both  # both, doctor, patient

# Debug Mode
DEBUG=false
TESTING=false
